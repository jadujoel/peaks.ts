{
	"browserslist": [
		"last 2 versions",
		"> 0.2%",
		"not IE 11"
	],
	"contributors": [
		"Chris Finch (https://github.com/chrisfinch)",
		"Thomas Parisot (https://github.com/oncletom)",
		"Chris Needham (https://github.com/chrisn)"
	],
	"dependencies": {
		"@jadujoel/typed-event-target": "0.0.6",
		"@jadujoel/web-audio-clip-node": "0.2.8",
		"neverthrow": "8.2.0",
		"option-t": "56.0.0"
	},
	"description": "Typescript UI component for displaying audio waveforms",
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@playwright/test": "^1.54.2",
		"@types/bun": "latest",
		"@types/pngjs": "6.0.5",
		"@types/sinon": "21.0.1",
		"@types/sinon-chai": "4.0.0",
		"@vitest/browser-playwright": "^4.0.7",
		"@vitest/coverage-v8": "^4.0.7",
		"pixi.js": "8.18.1",
		"playwright": "^1.54.2",
		"pngjs": "7.0.0",
		"sinon": "21.1.2",
		"sinon-chai": "4.0.1",
		"vite": "8.0.10",
		"vitest": "^4.0.7"
	},
	"engines": {
		"node": ">= 20.0.0"
	},
	"exports": {
		".": {
			"default": "./dist/peaks.esm.js",
			"import": "./dist/peaks.esm.js",
			"types": "./dist/esm/main.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"keywords": [
		"audio",
		"visualisation",
		"webaudio",
		"browser",
		"interactive",
		"waveform"
	],
	"license": "LGPL-3.0",
	"main": "./dist/peaks.esm.js",
	"module": "./dist/peaks.esm.js",
	"name": "@jadujoel/peaks.ts",
	"peerDependencies": {
		"konva": ">= 8.3.14 < 10",
		"pixi.js": "^8.0.0",
		"typescript": "^6",
		"waveform-data": ">= 4.5.1 < 5"
	},
	"peerDependenciesMeta": {
		"konva": {
			"optional": true
		},
		"pixi.js": {
			"optional": true
		}
	},
	"private": false,
	"publishConfig": {
		"access": "public",
		"provenance": true,
		"registry": "https://registry.npmjs.org/"
	},
	"repository": {
		"type": "git",
		"url": "git://github.com/jadujoel/peaks.ts.git"
	},
	"scripts": {
		"build": "bun scripts/build.ts",
		"check:no-konva-leak": "bun scripts/check-no-konva-leak.ts",
		"check:no-pixi-leak": "bun scripts/check-no-pixi-leak.ts",
		"example": "bun --filter @peaks/main-example dev",
		"example:build": "bun --filter @peaks/main-example build",
		"example:typecheck": "bun --filter @peaks/main-example typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"prebuild": "bun run check:no-konva-leak && bun run check:no-pixi-leak && bun run lint && bun run typecheck",
		"start": "bun --filter @peaks/main-example dev",
		"test": "vitest run",
		"test:all": "bun run lint && bun run typecheck && bun run test && bun run build && bun run test:e2e",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json"
	},
	"type": "module",
	"types": "./dist/esm/main.d.ts",
	"version": "5.0.1",
	"workspaces": [
		"workspaces/*"
	]
}
