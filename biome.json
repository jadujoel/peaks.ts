{
	"assist": {
		"actions": {
			"source": {
				"useSortedKeys": "on"
			}
		}
	},
	"files": {
		"includes": [
			"**",
			"!coverage",
			"!dist",
			"!playwright-report",
			"!test-results",
			"!workspaces/**/dist",
			"!workspaces/**/public"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"overrides": [
		{
			"includes": ["test/**/*.js", "test/**/*.ts"],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off"
					},
					"suspicious": {
						"noDuplicateTestHooks": "off",
						"noShadowRestrictedNames": "off"
					}
				}
			}
		},
		{
			"includes": ["src/**/*.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noAssignInExpressions": "off",
						"noImplicitAnyLet": "off",
						"noSelfCompare": "off",
						"noShadowRestrictedNames": "off"
					}
				}
			}
		}
	]
}
